{
  "schema": "aift.forge.tool-policy.v1",
  "id": "default",
  "mode": "local-first",
  "network": "local-only",
  "defaultDecision": "deny",
  "allowReadOnlyTools": true,
  "requireApprovalForWrite": true,
  "requireApprovalForShell": true,
  "allowedTools": [
    "repo.status",
    "repo.files",
    "repo.read",
    "git.status",
    "git.diff",
    "git.log",
    "knowledge.search",
    "knowledge.status"
  ],
  "deniedTools": [
    "shell.exec",
    "git.commit",
    "git.push",
    "file.write"
  ],
