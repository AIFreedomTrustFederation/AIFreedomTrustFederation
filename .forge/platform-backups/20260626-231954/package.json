{
  "name": "aift-root-apps",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/product-web",
    "apps/desktop",
    "apps/android",
    "apps/forge-api",
    "packages/forge-core"
  ],
  "scripts": {
    "verify": "node scripts/verify-forge-structure.mjs",
    "readiness": "node scripts/aift-forge-readiness.mjs",
    "deps:manifest": "node scripts/aift-dependency-manifest.mjs",
    "qa:deps": "npm run deps:manifest && npm run verify && npm run readiness",
    "qa:local": "npm run qa:deps && npm test && npm run lint && npm run smoke:git-access && npm run smoke:git-live && npm audit --audit-level=high && npm run web:build && npm run license:check",
    "smoke:git-access": "node scripts/smoke-git-access.mjs",
    "smoke:git-live": "node scripts/smoke-live-git-client.mjs",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sbom": "cyclonedx-npm --output-file dist/aift-forge-sbom.json",
    "license:check": "license-checker-rseidelsohn --summary --production",
    "api:dev": "node apps/forge-api/server.mjs",
    "web:dev": "npm --workspace apps/product-web run dev",
    "web:build": "npm --workspace apps/product-web run build",
    "desktop:dev": "npm --workspace apps/desktop run dev",
    "desktop:build:win": "npm --workspace apps/desktop run build:win",
    "android:sync": "npm --workspace apps/android run sync",
    "android:open": "npm --workspace apps/android run open",
    "android:build": "npm --workspace apps/android run build",
    "android:apk:collect": "npm --workspace apps/android run apk:collect",
    "build": "node scripts/aift-build-check.mjs",
    "typecheck": "node scripts/aift-typecheck-check.mjs",
    "deps:profile": "node scripts/aift-platform-deps.mjs profile",
    "deps:doctor": "node scripts/aift-platform-deps.mjs doctor",
    "deps:install": "node scripts/aift-platform-deps.mjs install"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "latest",
    "@playwright/test": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "license-checker-rseidelsohn": "^4.4.2",
    "prettier": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "aiftDesktopDependencies": {}
}
